# Copie este arquivo para `.env` e ajuste conforme o ambiente:
#   cp .env.example .env
#
# Todas as variáveis abaixo são obrigatórias. Valores vazios fazem o app falhar na inicialização.

# URL base da API RFB (sem barra final)
VITE_API_BASE_URL=http://localhost:5000

# Versão da API (deve corresponder ao versionamento do backend, ex.: 1.0)
VITE_API_VERSION=1.0

# Timeout das requisições HTTP em milissegundos
VITE_API_TIMEOUT_MS=30000
