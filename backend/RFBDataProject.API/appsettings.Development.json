{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=rfbdataproject_db;Username=postgres;Password=postgrespassword;Keepalive=30"
  },
  "Redis": {
    "ConnectionString": "",
    "InstanceName": "rfb:",
    "SearchCacheMinutes": 5
  },
  "Rfb": {
    "BaseUrls": [
      "https://dados-abertos-rf-cnpj.casadosdados.com.br/arquivos",
      "https://dadosabertos.rfb.gov.br/CNPJ/dados_abertos_cnpj",
      "https://arquivos.receitafederal.gov.br/dados/cnpj/dados_abertos_cnpj"
    ],
    "DownloadParallelism": 4,
    "ParserParallelism": 4,
    "StagingWriterParallelism": 2,
    "ChannelCapacity": 10000,
    "StagingBatchSize": 5000,
    "SyncIntervalHours": 24,
    "RunSyncOnStartup": false,
    "MaxDownloadRetries": 5,
    "UserAgent": "RFBDataProject/1.0"
  }
}
